# Database (Railway PostgreSQL)
# connection_limit ve pool_timeout production için önerilir
DATABASE_URL="postgresql://user:pass@host:5432/dbname?schema=public&connection_limit=20&pool_timeout=10"

# NextAuth
# openssl rand -base64 32 ile oluştur
NEXTAUTH_SECRET="generate-a-random-32-char-secret"
NEXTAUTH_URL="https://your-domain.railway.app"

# Cloudflare R2 (dosya yükleme)
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET_NAME="yasam-takibi"
R2_PUBLIC_URL="https://pub-xxx.r2.dev"

# OpenAI (AI chat, analiz, plan)
OPENAI_API_KEY="sk-your-openai-api-key"
OPENAI_MODEL="gpt-4o-mini"

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# Resend (e-posta)
RESEND_API_KEY="re_your-resend-api-key"
EMAIL_FROM="Şeyda <noreply@seyda.app>"

# Sentry (hata izleme)
SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
NEXT_PUBLIC_SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
SENTRY_AUTH_TOKEN="sntrys_xxx"
SENTRY_ORG="your-org"
SENTRY_PROJECT="seyda"

# Otomatik Yedekleme (Cron)
# openssl rand -hex 32 ile oluştur
CRON_SECRET="generate-a-random-hex-secret"
